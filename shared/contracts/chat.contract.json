{
  "version": "0.1.0",
  "endpoint": "POST /api/chat",
  "request": {
    "message": "string",
    "session_id": "string"
  },
  "response": {
    "answer": "string",
    "trace_id": "string",
    "needs_approval": "boolean"
  },
  "transcript": {
    "endpoint": "GET /api/chat/transcript/{trace_id}",
    "response": {
      "trace_id": "string",
      "steps": [
        {
          "step": "string",
          "agent": "string",
          "observation": "string",
          "sources": [
            {
              "title": "string",
              "path": "string"
            }
          ],
          "timestamp": "string"
        }
      ]
    }
  },
  "stream": {
    "endpoint": "GET /api/chat/stream?trace_id=<id>",
    "event": "trace_step",
    "payload": {
      "step": "string",
      "agent": "string",
      "observation": "string",
      "sources": [
        {
          "title": "string",
          "path": "string"
        }
      ]
    }
  },
  "actions": {
    "pending": {
      "endpoint": "GET /api/actions/pending",
      "response": {
        "actions": [
          {
            "id": "string",
            "trace_id": "string",
            "action": "string",
            "risk_level": "string",
            "reason": "string",
            "status": "pending",
            "created_at": "string"
          }
        ]
      }
    },
    "approve": {
      "endpoint": "POST /api/actions/{action_id}/approve",
      "request": {
        "decided_by": "string"
      },
      "response": {
        "action_id": "string",
        "status": "executed",
        "execution": {
          "action_id": "string",
          "trace_id": "string",
          "action": "string",
          "status": "mock_executed",
          "tool": "string",
          "message": "string"
        }
      }
    },
    "reject": {
      "endpoint": "POST /api/actions/{action_id}/reject",
      "request": {
        "decided_by": "string",
        "reason": "string"
      },
      "response": {
        "action_id": "string",
        "status": "rejected",
        "rejection_reason": "string"
      }
    }
  }
}
