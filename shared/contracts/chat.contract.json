{
  "version": "0.1.0",
  "endpoint": "POST /api/chat",
  "request": {
    "message": "string (optional)",
    "session_id": "string",
    "incident_report": {
      "source_system": "iris",
      "case_id": "string (optional)",
      "report_id": "string (optional)",
      "report_url": "string (optional)",
      "ingested_at": "string (optional)",
      "case_name": "string",
      "short_description": "string",
      "severity": "string",
      "tags": [
        "string"
      ],
      "iocs": [
        "string or object"
      ],
      "timeline": [
        "string or object"
      ]
    }
  },
  "request_rules": {
    "accepted_modes": [
      "message_only",
      "incident_report_only",
      "message_and_incident_report"
    ],
    "precedence": "When incident_report is present, backend derives canonical query context from incident_report and ignores message for controller query input."
  },
  "response": {
    "answer": "string",
    "trace_id": "string",
    "needs_approval": "boolean",
    "dedup_summary": {
      "documents": {
        "scanned": "number",
        "duplicates": "number"
      },
      "transcripts": {
        "scanned": "number",
        "duplicates": "number"
      },
      "deduped_count": "number",
      "duplication_ratio": "number",
      "last_run_at": "string|null"
    }
  },
  "ingestion": {
    "iris": {
      "endpoint": "POST /api/ingest/iris?case_id=<id>",
      "response": {
        "ingested_count": "number",
        "source": "iris",
        "case_id": "string",
        "incident_report": "IncidentReport"
      }
    },
    "confluence": {
      "endpoint": "POST /api/ingest/confluence",
      "request": {
        "page_ids": [
          "string"
        ]
      },
      "response": {
        "ingested_count": "number",
        "failed_count": "number",
        "source": "confluence",
        "results": [
          {
            "page_id": "string",
            "status": "ingested|failed",
            "title": "string|null",
            "error": "string|null"
          }
        ]
      }
    }
  },
  "approval": {
    "endpoint": "POST /api/approvals/{trace_id}",
    "request": {
      "decision": "approve|reject",
      "approver_id": "string",
      "comment": "string (optional)"
    },
    "response": {
      "trace_id": "string",
      "final_status": "executed|rejected",
      "approval": {
        "decision": "approve|reject",
        "approver_id": "string",
        "comment": "string",
        "timestamp": "string"
      },
      "execution_result": {
        "tool": "string",
        "status": "string",
        "output": "string",
        "timestamp": "string"
      }
    }
  },
  "transcript": {
    "endpoint": "GET /api/chat/transcript/{trace_id}",
    "response": {
      "trace_id": "string",
      "suggested_action": "string",
      "needs_approval": "boolean",
      "execution_status": "string",
      "final_status": "string (optional)",
      "approval": "object (optional)",
      "execution_result": "object (optional)",
      "dedup_summary": {
        "documents": {
          "scanned": "number",
          "duplicates": "number"
        },
        "transcripts": {
          "scanned": "number",
          "duplicates": "number"
        },
        "deduped_count": "number",
        "duplication_ratio": "number",
        "last_run_at": "string|null"
      },
      "steps": [
        {
          "step": "string",
          "agent": "string",
          "observation": "string",
          "sources": [
            {
              "title": "string",
              "path": "string"
            }
          ],
          "timestamp": "string"
        }
      ]
    }
  },
  "stream": {
    "endpoint": "GET /api/chat/stream?trace_id=<id>",
    "event": "trace_step",
    "payload": {
      "step": "string",
      "agent": "string",
      "observation": "string",
      "sources": [
        {
          "title": "string",
          "path": "string"
        }
      ]
    }
  }
}
